@startuml query-loop
!theme plain
title Claude Code - QueryEngine Query Loop

start

:User Input;
:processUserInput()\nnormalize to UserMessage;

:Build API Request;
note right
  - System prompt (context, tools, instructions)
  - User context (CLAUDE.md, memory files)
  - Tool schemas (40+ tool definitions)
  - Message history
  - Thinking config
end note

:Call Claude API\n(streaming);

fork
  :stream_event: message_start\nRecord initial usage;
fork again
  :stream_event: content_block_delta\nAccumulate text/tool_use;
fork again
  :stream_event: message_delta\nAccumulate usage;
fork again
  :stream_event: message_stop\nFinalize message;
end fork

:Yield AssistantMessage;

if (Contains ToolUseBlocks?) then (yes)
  :For each ToolUseBlock;

  :Find Tool by name\nfindToolByName();

  :Check Permission\ncanUseTool();

  if (Permission?) then (allow)
    :Execute tool.call()\nwith ToolUseContext;

    :Collect ToolResultBlock;

    if (Tool modifies context?) then (yes)
      :Apply contextModifier;
    else (no)
    endif

  else (deny)
    :Create denial ToolResult\n"Permission denied";
    :Track in permissionDenials[];
  endif

  :Create UserMessage\nwith all ToolResults;

  :Check token usage\nvs context window;

  if (Near context limit?) then (yes)
    :Auto-compact\ncompactConversation();
  else (no)
  endif

  if (maxTurns reached?) then (yes)
    :Return max_turns_reached;
    stop
  else (no)
    :Loop back to\nCall Claude API;
    note right
      Tool results become
      the next user message
      in the conversation
    end note
  endif

else (no)
  :Final response\n(text only);
endif

:Update AppState\nwith new messages;

:Yield final message;

stop

@enduml
