@startuml compaction-strategy
!theme plain
title Claude Code - Context Compaction Strategy

start

:Token usage updated\nafter API response;

:calculateTokenWarningState();
note right
  **Thresholds:**
  - Warning: contextWindow - 20K
  - Error: contextWindow - 20K
  - AutoCompact: contextWindow - 13K
  - Blocking: contextWindow - 3K
end note

if (isAutoCompactEnabled()?) then (no)
  :Skip compaction;
  stop
endif

if (querySource == 'compact'\nor 'session_memory'?) then (yes)
  :Skip (prevent recursion);
  stop
endif

if (Above auto-compact\nthreshold?) then (yes)

  :shouldAutoCompact() = true;

  if (Microcompact sufficient?) then (yes)
    :Run Microcompact;
    note right
      **Microcompact:**
      - Clear old tool result content
      - Replace with "[Old tool result
        content cleared]"
      - Time-based trigger evaluation
      - Quick token estimation
    end note
    stop
  else (no)
  endif

  :Run Full Compact;
  note right
    **Full Compact Steps:**
    1. stripImagesFromMessages()
    2. Build compact prompt
    3. Call Claude API for summary
    4. Create boundary marker
    5. Build summary messages
  end note

  :buildPostCompactMessages();
  note right
    Order:
    1. Boundary marker (SystemMessage)
    2. Summary messages (UserMessage[])
    3. Messages to keep
    4. Attachment messages
    5. Hook result messages
  end note

  :runPostCompactCleanup();
  note right
    **Restoration Budgets:**
    - Max 5 files (50K token budget)
    - Max 5K tokens per file
    - Max 25K tokens for skills
    - Max 5K tokens per skill
    - Truncate if exceeded
  end note

  :Update token counts;
  note right
    Track:
    - preCompactTokenCount
    - postCompactTokenCount
    - truePostCompactTokenCount
    - compactionUsage
  end note

  if (Post-compact still\nabove threshold?) then (yes)
    :Increment consecutiveFailures;

    if (Recompaction allowed?) then (yes)
      :Track recompaction info;
      note right
        RecompactionInfo:
        - isRecompactionInChain
        - turnsSincePreviousCompact
        - previousCompactTurnId
        - autoCompactThreshold
      end note
      :Re-run compaction\n(recursive);
    else (no)
      :Warn user\n"Context near limit";
    endif
  else (no)
    :Compaction successful;
  endif

  stop

else (no)

  if (Above warning\nthreshold?) then (yes)
    :Display warning\n"Context window filling up";
  else (no)
  endif

  if (API returns\nprompt_too_long?) then (yes)
    :Reactive compact\n(forced);
    note right
      Triggered by API error
      rather than proactive check.
      Feature flag: tengu_cobalt_raccoon
      can suppress proactive,
      relying on reactive only.
    end note
  else (no)
  endif

  stop
endif

@enduml
